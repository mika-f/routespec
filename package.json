{
  "name": "@natsuneko-laboratory/routespec",
  "version": "0.1.0",
  "description": "Generate OpenAPI documents from annotated Next.js Route Handlers.",
  "license": "MIT",
  "bin": {
    "routespec": "./src/cli.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./helpers": {
      "types": "./src/helpers.ts",
      "import": "./src/helpers.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "next": "^16.2.7",
    "vitest": "^4.1.9",
    "zod": "^3.25.0"
  },
  "peerDependencies": {
    "next": ">=15.2.0",
    "zod": "^3.25.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
